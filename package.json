{
  "name": "@warren-bank/Android-IPTV-M3U-Channel-List-Viewer",
  "private": true,
  "license": "GPL-2.0",
  "devDependencies": {
    "@warren-bank/translate-android-strings": "^3.0.1"
  },
  "scripts": {
    "translate":       "translate-android-strings -s \"deepl\" -i \"en\" -f \"android-studio-project/M3U-Viewer/src/main/res/values/strings.xml\" -d \"android-studio-project/M3U-Viewer/src/withAllLanguageTranslations/res\" -m --na --nc --nw -b \"(?:M3U|URL|http|[\\x22])\"",
    "translate:debug": "npm run translate -- -o \"en\" --debug"
  }
}
